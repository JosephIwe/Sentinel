# ==============================================================================
# Sentinel API Intelligence Platform - Environment Variables
# ==============================================================================

# Server & Runtime Configuration (Optional)
# PORT: The port the Express server binds to (Defaults to 3000)
PORT="3000"
# NODE_ENV: Runtime environment (e.g. development, production)
NODE_ENV="production"

# AI Meta-Analysis Core API (Required)
# GEMINI_API_KEY: Secret key used to access Gemini models for report summaries and deep intelligence analysis.
# Set via your hosting environment or local .env file.
GEMINI_API_KEY="your-gemini-api-key-here"

# Connector Credential Config (Optional)
# GITHUB_TOKEN: GitHub Personal Access Token (PAT) to perform high-rate-limit scans via the GitHub REST API.
GITHUB_TOKEN=""

# Cache TTL Configurations in Milliseconds (Optional)
# WHOIS_CACHE_TTL_MS: TTL duration for domain registry WHOIS lookups. Defaults to 3600000 (1 hour).
WHOIS_CACHE_TTL_MS="3600000"

# DNS_CACHE_TTL_MS: TTL duration for active authoritative query loops. Defaults to 300000 (5 minutes).
DNS_CACHE_TTL_MS="300000"

# GITHUB_CACHE_TTL_MS: TTL duration for GitHub repository scanners. Defaults to 3600000 (1 hour).
GITHUB_CACHE_TTL_MS="3600000"

# INVESTIGATION_CACHE_TTL_MS: TTL duration for aggregated investigation scans. Defaults to 300000 (5 minutes).
INVESTIGATION_CACHE_TTL_MS="300000"
