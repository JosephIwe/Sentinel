datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String          @unique
  emailVerified Boolean         @default(false)
  image         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  companyName   String?
  plan          String          @default("Free") // "Free" | "Pro" | "Enterprise"
  
  sessions      Session[]
  accounts      Account[]
  apiKeys       ApiKey[]
  investigations Investigation[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  expiresAt             DateTime?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model ApiKey {
  id          String      @id @default(cuid())
  userId      String
  name        String
  secret      String      @unique // securely stored representation
  prefix      String      // e.g. "sn_live"
  status      String      @default("active") // "active" | "revoked"
  rateLimit   Int         @default(300) // requests per minute
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  lastUsedAt  DateTime?
  
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  usageLogs   ApiUsage[]

  @@map("api_keys")
}

model ApiUsage {
  id           String    @id @default(cuid())
  apiKeyId     String
  endpoint     String
  method       String
  statusCode   Int
  latencyMs    Int
  tokensUsed   Int       @default(0)
  ipAddress    String?
  createdAt    DateTime  @default(now())

  apiKey       ApiKey    @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([apiKeyId, createdAt])
  @@map("api_usage")
}

model Investigation {
  id               String    @id @default(cuid())
  userId           String
  targetUrl        String?
  rawText          String?
  schemaType       String
  schemaDefinition String    // JSON string definition
  status           String    @default("pending") // "pending" | "processing" | "completed" | "failed"
  resultPayload    String?   // JSON result payload string
  durationMs       Int?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("investigations")
}
